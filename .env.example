# Moomoo OpenD
MOOMOO_OPEND_HOST=127.0.0.1
# JavaScript SDK uses the OpenD websocket port, not the TCP API port.
MOOMOO_OPEND_WS_PORT=33333
MOOMOO_OPEND_WS_SSL=false
MOOMOO_OPEND_WS_KEY=
MOOMOO_OPEND_WS_KEY_FILE=./secrets/moomoo_opend_ws_key.txt

# Trading account. Run `npm run moomoo:check` to list masked accounts.
MOOMOO_ACC_ID=
MOOMOO_TRD_ENV=simulate
MOOMOO_TRD_MARKET=US
MOOMOO_JP_ACC_TYPE=

# Strict local-only simulation policy. Defaults also come from sim-trading-policy.json.
MOOMOO_REQUIRED_ADVICE_FORMAT=pa
MOOMOO_MIN_WIN_RATE=80
MOOMOO_MIN_CONFIDENCE=5
MOOMOO_MAX_RISK_SCORE=2
MOOMOO_PAPER_EQUITY_USD=10000
MOOMOO_POSITION_TARGET_PCT=25
MOOMOO_POSITION_MIN_PCT=20
MOOMOO_POSITION_MAX_PCT=30
MOOMOO_UNDERLYING_TAKE_PROFIT_PCT=50
MOOMOO_UNDERLYING_STOP_LOSS_PCT=20

# Conservative execution-quality model for options.
MOOMOO_OPTION_REQUIRE_BID_ASK=true
MOOMOO_OPTION_MIN_BID_PRICE=0.01
MOOMOO_OPTION_MAX_SPREAD_PCT_OF_MID=25
MOOMOO_OPTION_MAX_SPREAD_ABS=1
MOOMOO_OPTION_MAX_ROUND_TRIP_LOSS_PCT=40
MOOMOO_OPTION_SLIPPAGE_TICKS=1
MOOMOO_OPTION_SLIPPAGE_PCT_OF_SPREAD=10
MOOMOO_OPTION_CAP_QTY_BY_VISIBLE_ASK=true
MOOMOO_OPTION_MAX_QTY_TO_ASK_VOLUME_RATIO=10
MOOMOO_OPTION_MIN_OPEN_INTEREST=50
MOOMOO_OPTION_MIN_DAY_VOLUME=1
MOOMOO_QUOTE_PUSH_WARMUP_MS=350
MOOMOO_QUOTE_FALLBACK_SNAPSHOT_MAX_AGE_MS=2000

# Leave quantity empty to let the local program size contracts from option price.
MOOMOO_OPTION_QTY=
MOOMOO_MAX_OPTION_QTY=

# Real trading remains disabled unless both this flag and the CLI real-execute flag are set.
MOOMOO_ALLOW_REAL_TRADING=false
